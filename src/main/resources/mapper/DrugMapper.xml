<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.twelfth_module.mapper.DrugMapper">

    <resultMap id="BaseResultMap" type="org.example.twelfth_module.entity.Drug">
        <id column="id" property="id"/>
        <result column="drug_code" property="drugCode"/>
        <result column="drug_name" property="drugName"/>
        <result column="generic_name" property="genericName"/>
        <result column="specification" property="specification"/>
        <result column="unit" property="unit"/>
        <result column="manufacturer" property="manufacturer"/>
        <result column="category" property="category"/>
        <result column="contraindication" property="contraindication"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM drug WHERE status = 1 ORDER BY drug_name
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM drug WHERE id = #{id}
    </select>

</mapper>
